{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "search-window",
  "description": "Read-only and window-internal permissions for the Spotlight search window.",
  "windows": ["search"],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-center",
    "allow-get-settings",
    "allow-search-files",
    "allow-get-paged-files",
    "allow-get-operation-previews-for-scope",
    "allow-get-stats-summary",
    "allow-get-runtime-capabilities",
    "allow-activate-search-result",
    "allow-resize-search-window"
  ]
}
