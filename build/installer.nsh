!define MUI_ABORTWARNING
!define MUI_WELCOMEPAGE_TITLE "Install Zen Canvas / 安装 Zen Canvas"
!define MUI_WELCOMEPAGE_TEXT "Zen Canvas is a lightweight local-first file lifecycle assistant.$\r$\n$\r$\nSearch, scan, preview, organize, and restore personal files with a calm native workflow. Real move or rename operations always require confirmation.$\r$\n$\r$\nYour index stays on this device. Zen Canvas does not upload your files by default."
!define MUI_DIRECTORYPAGE_TEXT_TOP "Choose where Zen Canvas should be installed. The default user location is recommended for most users and keeps updates simple."
!define MUI_FINISHPAGE_TITLE "Zen Canvas is ready"
!define MUI_FINISHPAGE_TEXT "Zen Canvas has been installed. Launch it now, choose a folder, and start with a manual scan of your personal files."
!define MUI_FINISHPAGE_RUN_TEXT "Launch Zen Canvas"
